[color]
  branch = auto
  diff = auto
  interactive = auto
  status = auto
  ui = auto

[color "branch"]
  current = green
  remote = yellow

[core]
  pager = less -FRSX
  editor = code --wait

[alias]
  co = checkout
  st = status -sb
  br = branch
  ci = commit
  fo = fetch origin
  d = !git --no-pager diff
  dt = difftool
  stat = !git --no-pager diff --stat

  # Détecte et pointe vers la branche par défaut (main ou master)
  remoteSetHead = remote set-head origin --auto
  defaultBranch = !git symbolic-ref refs/remotes/origin/HEAD | cut -d'/' -f4

  # Supprime les branches mergées localement + prune remote
  sweep = !git branch --merged $(git defaultBranch) | grep -E -v " $(git defaultBranch)$" | xargs -r git branch -d && git remote prune origin

  # Joli log avec graph
  lg = log --graph --all --pretty=format:'%Cred%h%Creset - %s %Cgreen(%cr) %C(bold blue)%an%Creset %C(yellow)%d%Creset'

  # Checkout vers la branche par défaut
  m = !git checkout $(git defaultBranch)

  # Retire un fichier du staging
  unstage = reset HEAD --

[help]
  autocorrect = 1

[push]
  default = simple

[pull]
  rebase = false

[init]
  defaultBranch = main

